<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lowcode.platform.form.mapper.FormDefinitionMapper">

    <select id="selectByFormCode" resultType="com.lowcode.platform.form.entity.FormDefinition">
        SELECT * FROM form_definition WHERE form_code = #{formCode} AND del_flag = 0
    </select>

</mapper>
