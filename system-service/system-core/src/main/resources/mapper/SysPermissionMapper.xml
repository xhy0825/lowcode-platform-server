<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lowcode.platform.system.mapper.SysPermissionMapper">

    <resultMap id="SysPermissionResult" type="com.lowcode.platform.system.entity.SysPermission">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="permission_name" property="permissionName"/>
        <result column="permission_code" property="permissionCode"/>
        <result column="permission_type" property="permissionType"/>
        <result column="parent_id" property="parentId"/>
        <result column="path" property="path"/>
        <result column="component" property="component"/>
        <result column="redirect" property="redirect"/>
        <result column="icon" property="icon"/>
        <result column="order_num" property="orderNum"/>
        <result column="visible" property="visible"/>
        <result column="api_path" property="apiPath"/>
        <result column="api_method" property="apiMethod"/>
        <result column="status" property="status"/>
        <result column="del_flag" property="delFlag"/>
    </resultMap>

    <select id="selectPermissionsByUserId" resultMap="SysPermissionResult">
        SELECT p.* FROM sys_permission p
        INNER JOIN sys_role_permission rp ON p.id = rp.permission_id
        INNER JOIN sys_user_role ur ON rp.role_id = ur.role_id
        WHERE ur.user_id = #{userId} AND p.del_flag = 0 AND p.status = 0
        ORDER BY p.order_num
    </select>

    <select id="selectMenuTree" resultMap="SysPermissionResult">
        SELECT * FROM sys_permission
        WHERE permission_type = 'menu' AND del_flag = 0 AND status = 0
        ORDER BY order_num
    </select>

</mapper>