<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lowcode.platform.data.mapper.DataModelMapper">

    <!-- 根据编码查询 -->
    <select id="selectByModelCode" resultType="com.lowcode.platform.data.entity.DataModel">
        SELECT * FROM data_model WHERE model_code = #{modelCode} AND del_flag = 0
    </select>

    <!-- 查询模型的字段列表 -->
    <select id="selectFieldsByModelId" resultType="com.lowcode.platform.data.entity.DataModelField">
        SELECT * FROM data_model_field WHERE model_id = #{modelId} AND del_flag = 0 ORDER BY order_num ASC
    </select>

</mapper>
