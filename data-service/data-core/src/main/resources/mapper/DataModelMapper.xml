<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lowcode.platform.data.mapper.DataModelMapper">

    <resultMap id="DataModelResult" type="com.lowcode.platform.data.entity.DataModel">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="model_name" property="modelName"/>
        <result column="model_code" property="modelCode"/>
        <result column="table_name" property="tableName"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="version" property="version"/>
        <result column="del_flag" property="delFlag"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_time" property="createdTime"/>
    </resultMap>

    <resultMap id="DataModelFieldResult" type="com.lowcode.platform.data.entity.DataModelField">
        <id column="id" property="id"/>
        <result column="model_id" property="modelId"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="field_name" property="fieldName"/>
        <result column="field_code" property="fieldCode"/>
        <result column="column_name" property="columnName"/>
        <result column="field_type" property="fieldType"/>
        <result column="length" property="length"/>
        <result column="precision" property="precision"/>
        <result column="scale" property="scale"/>
        <result column="is_required" property="isRequired"/>
        <result column="is_unique" property="isUnique"/>
        <result column="is_indexed" property="isIndexed"/>
        <result column="is_primary" property="isPrimary"/>
        <result column="default_value" property="defaultValue"/>
        <result column="dict_type" property="dictType"/>
        <result column="relation_type" property="relationType"/>
        <result column="relation_model_id" property="relationModelId"/>
        <result column="order_num" property="orderNum"/>
    </resultMap>

    <select id="selectByModelCode" resultMap="DataModelResult">
        SELECT * FROM data_model WHERE model_code = #{modelCode} AND del_flag = 0
    </select>

    <select id="selectFieldsByModelId" resultMap="DataModelFieldResult">
        SELECT * FROM data_model_field WHERE model_id = #{modelId} AND del_flag = 0 ORDER BY order_num
    </select>

</mapper>